# Frontend (build-time; used by Vite)
# Copy to .env and set before building for production.
# For Heroku/Vercel/Netlify set these in the dashboard.

# Backend API base URL (no trailing slash). Required for production.
# Example: https://your-api.herokuapp.com
VITE_BASE_URL=http://localhost:4001

# Paystack public key (if using payments)
# VITE_PAYSTACK_PUBLIC_KEY=pk_live_...
